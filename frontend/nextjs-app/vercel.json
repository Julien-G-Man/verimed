{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "@api-url"
  },
  "envs": {
    "production": {
      "env": {
        "NEXT_PUBLIC_API_URL": "https://verimed-api.onrender.com"
      }
    },
    "preview": {
      "env": {
        "NEXT_PUBLIC_API_URL": "https://verimed-api.onrender.com"
      }
    }
  },
  "regions": ["iad1"],
  "functions": {
    "api/**": {
      "memory": 3008,
      "maxDuration": 60
    }
  }
}
